generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  HR
  CANDIDATE
  RECRUITER
}

enum AuthProvider {
  MANUAL
  GOOGLE
  LINKEDIN
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  role      UserRole

  passwordHash     String?
  authProvider     AuthProvider @default(MANUAL)
  externalId       String?
  consentGiven     Boolean      @default(false)
  consentTimestamp DateTime?
  profilePicture   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  issuedCredentials     VerifiableCredential[] @relation("Issuer")
  heldCredentials       VerifiableCredential[] @relation("Holder")
  verificationsSent     VerificationRequest[]  @relation("Verifier")
  verificationsReceived VerificationRequest[]  @relation("VerificationHolder")
  credentialDrafts      CredentialDraft[]      @relation("CandidateDrafts")
  consentActions        DraftConsentAudit[]    @relation("ConsentActor")

  @@index([authProvider, externalId])
  @@map("users")
}

model VerifiableCredential {
  id        String    @id @default(cuid())
  issuerId  String
  holderId  String
  type      String
  claims    Json
  issuedAt  DateTime  @default(now())
  expiresAt DateTime?
  revoked   Boolean   @default(false)

  issuer   User                    @relation("Issuer", fields: [issuerId], references: [id])
  holder   User                    @relation("Holder", fields: [holderId], references: [id])
  requests VerificationRequest[]

  @@map("verifiable_credentials")
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CredentialStatus {
  DRAFT_SUBMITTED
  HR_REVIEWING
  HR_APPROVED
  REVISIONS_REQUIRED
  ISSUED
  REJECTED
}

model VerificationRequest {
  id           String             @id @default(cuid())
  verifierId   String
  holderId     String
  credentialId String
  status       VerificationStatus @default(PENDING)
  requestedAt  DateTime           @default(now())
  resolvedAt   DateTime?

  verifier   User                 @relation("Verifier", fields: [verifierId], references: [id])
  holder     User                 @relation("VerificationHolder", fields: [holderId], references: [id])
  credential VerifiableCredential @relation(fields: [credentialId], references: [id])

  @@map("verification_requests")
}

model Company {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  credentialDrafts CredentialDraft[]

  @@map("companies")
}

model CredentialDraft {
  id             String           @id @default(uuid())
  candidateId    String
  companyId      String
  content        Json
  status         CredentialStatus @default(DRAFT_SUBMITTED)
  magicTokenHash String          @unique
  tokenExpiresAt DateTime
  consentLogged  Boolean         @default(false)
  hrFeedback     String?
  reviewedAt     DateTime?
  credentialHash String?         @unique
  signature      String?
  signatoryPubKey String?
  issuedAt       DateTime?
  purgeAfterAt   DateTime?
  purgedAt       DateTime?
  purgeStatus    PurgeStatus      @default(NONE)
  privacyPolicyVersion String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  candidate User    @relation("CandidateDrafts", fields: [candidateId], references: [id])
  company   Company @relation(fields: [companyId], references: [id])
  consentAudits DraftConsentAudit[]
  complianceLogs ComplianceAuditLog[]

  @@index([tokenExpiresAt, status])
  @@map("credential_drafts")
}

model DraftConsentAudit {
  id                      String   @id @default(uuid())
  draftId                 String
  actorUserId             String
  action                  CredentialStatus
  consentStatementVersion String
  consentCapturedAt       DateTime @default(now())
  ipHash                  String?
  userAgentHash           String?

  draft     CredentialDraft @relation(fields: [draftId], references: [id])
  actorUser User            @relation("ConsentActor", fields: [actorUserId], references: [id])

  @@index([draftId, consentCapturedAt])
  @@map("draft_consent_audits")
}

enum PurgeStatus {
  NONE
  SCHEDULED
  PURGED
}

model ComplianceAuditLog {
  id                    String   @id @default(uuid())
  draftId               String
  action                String
  actorUserId           String?
  actorMagicTokenHash   String?
  privacyPolicyVersion  String
  actionTimestamp       DateTime @default(now())
  notes                 String?

  draft CredentialDraft @relation(fields: [draftId], references: [id])

  @@index([draftId, actionTimestamp])
  @@map("compliance_audit_logs")
}
