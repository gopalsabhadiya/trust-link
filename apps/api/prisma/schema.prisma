generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  HR
  CANDIDATE
  RECRUITER
}

enum AuthProvider {
  MANUAL
  GOOGLE
  LINKEDIN
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  role      UserRole

  passwordHash     String?
  authProvider     AuthProvider @default(MANUAL)
  externalId       String?
  consentGiven          Boolean   @default(false)
  consentTimestamp      DateTime?
  /** Privacy policy version accepted with consent (e.g. DPDP-2026-v1). */
  consentPolicyVersion  String?
  profilePicture        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  issuedCredentials     VerifiableCredential[] @relation("Issuer")
  heldCredentials       VerifiableCredential[] @relation("Holder")
  verificationsSent     VerificationRequest[]  @relation("Verifier")
  verificationsReceived VerificationRequest[]  @relation("VerificationHolder")
  credentialCases       CredentialCase[]       @relation("CandidateCredentialCases")
  consentActions        DraftConsentAudit[]    @relation("ConsentActor")

  @@index([authProvider, externalId])
  @@map("users")
}

model VerifiableCredential {
  id        String    @id @default(cuid())
  issuerId  String
  holderId  String
  type      String
  claims    Json
  issuedAt  DateTime  @default(now())
  expiresAt DateTime?
  revoked   Boolean   @default(false)

  issuer   User                    @relation("Issuer", fields: [issuerId], references: [id])
  holder   User                    @relation("Holder", fields: [holderId], references: [id])
  requests VerificationRequest[]

  @@map("verifiable_credentials")
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CredentialStatus {
  DRAFT_SUBMITTED
  HR_REVIEWING
  HR_APPROVED
  REVISIONS_REQUIRED
  ISSUED
  REJECTED
}

model VerificationRequest {
  id           String             @id @default(cuid())
  verifierId   String
  holderId     String
  credentialId String
  status       VerificationStatus @default(PENDING)
  requestedAt  DateTime           @default(now())
  resolvedAt   DateTime?

  verifier   User                 @relation("Verifier", fields: [verifierId], references: [id])
  holder     User                 @relation("VerificationHolder", fields: [holderId], references: [id])
  credential VerifiableCredential @relation(fields: [credentialId], references: [id])

  @@map("verification_requests")
}

model Company {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  credentialCases CredentialCase[]

  @@map("companies")
}

/// Employment credential thread (one logical experience-letter journey).
model CredentialCase {
  id               String   @id @default(uuid())
  candidateId      String
  companyId        String
  currentVersionId String?  @unique
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  candidate User @relation("CandidateCredentialCases", fields: [candidateId], references: [id])
  company   Company @relation(fields: [companyId], references: [id])

  versions       CredentialDraftVersion[]
  currentVersion CredentialDraftVersion?  @relation("CaseCurrentVersion", fields: [currentVersionId], references: [id])
  snapshots      IssuedCredentialSnapshot[]

  @@index([candidateId])
  @@map("credential_cases")
}

/// Append-only version history for a case; HR magic link is always bound to one version row.
model CredentialDraftVersion {
  id             String           @id @default(uuid())
  caseId         String
  versionNumber  Int
  content        Json
  status         CredentialStatus @default(DRAFT_SUBMITTED)
  magicTokenHash String?          @unique
  tokenExpiresAt DateTime?
  consentLogged  Boolean          @default(false)
  /// Normalized reviewer email from candidate submission (HR authZ).
  hrReviewEmail  String?
  hrFeedback     String?
  reviewedAt     DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  case           CredentialCase           @relation(fields: [caseId], references: [id])
  currentForCase CredentialCase?          @relation("CaseCurrentVersion")
  issuedSnapshot IssuedCredentialSnapshot?
  consentAudits  DraftConsentAudit[]
  complianceLogs ComplianceAuditLog[]

  @@unique([caseId, versionNumber])
  @@index([caseId, versionNumber])
  @@map("credential_draft_versions")
}

enum PurgeStatus {
  NONE
  SCHEDULED
  PURGED
}

/// Immutable issuance artifact; supports revocation without rewriting history.
model IssuedCredentialSnapshot {
  id                   String      @id @default(uuid())
  caseId               String
  sourceVersionId      String      @unique
  credentialHash       String      @unique
  signature            String
  signatoryPubKey      String
  contentSnapshot      Json
  issuedAt             DateTime    @default(now())
  revokedAt            DateTime?
  revocationReason     String?
  privacyPolicyVersion String?
  purgeAfterAt         DateTime?
  purgedAt             DateTime?
  purgeStatus          PurgeStatus @default(NONE)

  case    CredentialCase         @relation(fields: [caseId], references: [id])
  version CredentialDraftVersion @relation(fields: [sourceVersionId], references: [id])

  @@index([caseId])
  @@index([credentialHash])
  @@map("issued_credential_snapshots")
}

model DraftConsentAudit {
  id                      String   @id @default(uuid())
  versionId               String
  actorUserId             String
  action                  CredentialStatus
  consentStatementVersion String
  consentCapturedAt       DateTime @default(now())
  ipHash                  String?
  userAgentHash           String?

  version   CredentialDraftVersion @relation(fields: [versionId], references: [id])
  actorUser User                   @relation("ConsentActor", fields: [actorUserId], references: [id])

  @@index([versionId, consentCapturedAt])
  @@map("draft_consent_audits")
}

model ComplianceAuditLog {
  id                   String   @id @default(uuid())
  versionId            String
  action               String
  actorUserId          String?
  actorMagicTokenHash  String?
  privacyPolicyVersion String
  actionTimestamp      DateTime @default(now())
  notes                String?

  version CredentialDraftVersion @relation(fields: [versionId], references: [id])

  @@index([versionId, actionTimestamp])
  @@map("compliance_audit_logs")
}
